<%- include('../header', { title: 'Dashboard Magasinier' }) %>

<h2>Tableau de Bord Magasinier</h2>

<div class="card mt-4">
    <h3>Soumettre une nouvelle session</h3>
    <form action="/magasinier/sessions" method="POST" novalidate>
        <div class="form-group">
            <label for="nbArticles">Nombre d'articles</label>
            <input type="number" id="nbArticles" name="nbArticles" min="1">
        </div>
        <div class="form-group">
            <label for="tempsPasse">Temps passé (en heures)</label>
            <input type="number" id="tempsPasse" name="tempsPasse" min="0.1" step="0.1">
        </div>
        <button type="submit" class="btn">Soumettre</button>
    </form>
</div>

<div class="card mt-4">
    <h3>Historique de vos sessions</h3>
    <p>Taux horaire: <strong><%= user.tauxHoraire %> Dhs/h</strong></p>
    <table>
        <thead>
            <tr>
                <th>Date</th>
                <th>Nb Articles</th>
                <th>Quota (H)</th>
                <th>Temps Passé (H)</th>
                <th>Temps Calculé (H)</th>
                <th>Erreur</th>
                <th>Salaire (Dhs)</th>
            </tr>
        </thead>
        <tbody>
            <% userSessions.forEach(function(s) { %>
                <tr>
                    <td><%= new Date(s.date).toLocaleString() %></td>
                    <td><%= s.nbArticles %></td>
                    <td><%= s.Quota %></td>
                    <td><%= s.tempsPasse %></td>
                    <td><%= s.tempsCalcule %></td>
                    <td>
                        <% if (s.erreur) { %>
                            <span class="badge badge-danger">Oui (Malus +1h)</span>
                        <% } else { %>
                            <span class="badge badge-success">Non</span>
                        <% } %>
                    </td>
                    <td><strong><%= s.salaire.toFixed(2) %></strong></td>
                </tr>
            <% }); %>
            
            <% if (userSessions.length === 0) { %>
                <tr><td colspan="7" class="text-center">Aucune session enregistrée</td></tr>
            <% } %>
        </tbody>
    </table>
</div>

<%- include('../footer') %>
